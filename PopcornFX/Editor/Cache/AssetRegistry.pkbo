CEditorTemplateEntry	$AA59DDC1
{
	CustomName = "rgb to hsv";
	ClassType = Math;
	Description = {
		"@eng:Converts an `RGB`/`RGBA` color to the `HSV`/`HSVA` colorspace.\\n\\nThe output `Hue` and `Saturation` will always be in the `[0,1]` range.\\nThe output `Value` will be in the `[0,1]` range if the input `RGB` is not an HDR color. Otherwise, if it is an HDR color, `Value` will go above `1.0` accordingly.",
	};
	Public = true;
	IconKey = "Toolbar_PaintPalette";
	SearchKeywords = "colorspace convert conversion";
	EmitDeprecationWarning = true;
	ObjectUID = 1414353402;
	InputTypes = {
