CEditorTemplateEntry	$7604196C
{
	CustomName = "InterpolateTriangle";
	ClassType = Math;
	Description = {
		"@eng:Interpolates the 3 vertex values of a triangle `Value1`, `Value2`, `Value3` using the barycentric coordinates specified in the `UV` input.\\n\\nThe barycentric coordinates of each of the 3 vertex inputs are assumed to be:\\n`Value1`: `{0, 0}` (1st vertex)\\n`Value2`: `{1, 0}` (2nd vertex in CW order)\\n`Value3`: `{0, 1}` (3rd vertex in CW order)",
	};
