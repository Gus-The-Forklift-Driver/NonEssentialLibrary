CEditorTemplateEntry	$3C432720
{
	CustomName = "Color lerp";
	ClassType = Math;
	Description = {
		"@eng:Interpolates between `ColorA` and `ColorB`.\\nPerforms the interpolation **in HSV space**, producing clean Hue gradients.\\n\\nThe input colors can be `RGB` or `RGBA`, but must have the same vector dimension (Either both `RGB` or both `RGBA`, but not one `RGB` and the other `RGBA`)",
	};
	Public = true;
	IconKey = "Toolbar_PaintPalette";
	SearchKeywords = "color constructor assembler";
