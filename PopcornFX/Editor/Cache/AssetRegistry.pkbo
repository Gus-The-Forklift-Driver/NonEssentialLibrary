CEditorTemplateEntry	$AA8C96A0
{
	CustomName = "mesh.tetraIDToVertexIDs";
	ClassType = Sampler;
	Description = {
		"@eng:Given the index of a tetrahedron in the mesh, outputs the index of each of the 4 tetrahedron vertices, packed in an `int4`.\\n**NOTE:** As there can be more tetra vertices than mesh surface vertices, some of the vertex indices can go beyond the value returned by `Mesh.vertexCount()`.\\n\\nThese indices can be used to sample the mesh in `Vertex` mode by building a `PCoord` using the `shape.buildParametricCoords` node.",
	};
	Public = true;
	IconKey = "Resource_Mesh";
	EmitDeprecationWarning = true;
	ObjectUID = -1996802264;
	InputTypes = {
