CEditorTemplateEntry	$D5D3D67F
{
	CustomName = "Localspace";
	ClassType = Math;
	Description = {
		"@eng:Makes a position or direction localspace.\\nThis will offset and rotate the input position every frame by how much the parent effect instance has moved or rotated.\\nThis cause the input position to \"follow\" the parent effect instance, making it localspace.\\n\\nFor example, wire the <c>Position</c> and <c>Velocity</c> outputs from a physics node into this node to make the particle follow the parent effect instance as it moves through the world.\\n",
	};
	Public = true;
	EmitDeprecationWarning = true;
	ObjectUID = 1179092637;
	InputTypes = {
