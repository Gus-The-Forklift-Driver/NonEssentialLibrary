CEditorTemplateEntry	$AEE6D4A8
{
	CustomName = "GBuffer_ProjectToNormal";
	Description = {
		"@eng:Projects the input world position onto the GBuffer and extracts a normal at that location:\\n<ul>\\n<li><b>Input position</b> is converted to <b>screen space coordinates</b></li>\\n<li><b>Screen space coordinates</b> are used to sample the <b>Normal buffer</b></li>\\n</ul>\\n<c>Only supported if used with GPU simulated particles</c>.\\n\\nTo enable that feature in PopcornFX Editor, browse to <b>Project Settings > Features</b> and make sure to enable <b>GBuffer Sampling</b>.",
	};
	Public = true;
