CEditorTemplateEntry	$CEFFFC42
{
	CustomName = "randsel";
	ClassType = Math;
	Description = {
		"@eng:Randomly returns <c>ValueA</c> or <c>ValueB</c>.\\n\\nBy default, has an equal probability to return any of the two inputs.\\nChanging the value of <c>Cursor</c> will bias the probability towards the first or second input:\\n<c>Cursor = 0.1</c> will have a <b>10% chance</b> of returning <c>ValueB</c>, and a <b>90% chance</b> of returning <c>ValueA</c>.\\n<c>Cursor = 0.75</c> will have a <b>75% chance</b> of returning <c>ValueB</c>, and a <b>25% chance</b> of returning <c>ValueA</c>.\\n\\nlogic:\\n<c>select(a, b, rand(0,1) < k);</c>",
	};
	Public = true;
	IconKey = "Node_Math_Rand";
	EmitDeprecationWarning = true;
	ObjectUID = -408437106;
	InputTypes = {
		"$4A464F2D",
		"$5EFF56F4",
		"$AB4086C7",
	};
	OutputTypes = {
		"$4CB5B996",
	};
}
