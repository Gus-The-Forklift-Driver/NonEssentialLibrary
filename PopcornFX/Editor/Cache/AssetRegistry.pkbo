	ClassType = Event;
	GraphUsage = SimulationGraph;
	Description = {
		"@eng:Triggers a single event when the particle dies.\\nEvents are used to spawn child particles.\\n\\nDoes not trigger a death event if the effect has been stopped, unless `EvenWhenEffectStopped` is set to `true`.\\n\\nBasic trigger, does not add any helper payloads.\\nSee `OnDeath` if you need some base payloads.",
