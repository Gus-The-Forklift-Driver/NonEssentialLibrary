CEditorTemplateEntry	$2F216384
{
	CustomName = "sim.wave.size_live";
	ClassType = Math;
	Description = {
		"@eng:Returns the current simulation wavefront size.\\nThis is the effective size ignoring control-flow & which lanes are active.\\nIn CPU simulations, this will be wavefront size in particles, which is the number of valid particles in the current memory page.\\nIn GPU simulations, this will be lower or equal to the hardware wavefront/warp size depending on how many valid particles it contains.\\nThe number of \"valid\" particles is usually the number of particles alive in the wavefront, except on the evolve-on-death CPU sim stage that runs on the dead particle\'s last frame before they are deleted, where it\'ll be the number of dead particles.",
	};
	Public = true;
	EmitDeprecationWarning = true;
	ObjectUID = 1819587175;
	OutputTypes = {
