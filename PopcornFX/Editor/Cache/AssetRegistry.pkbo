CEditorTemplateEntry	$F3FA211F
{
	CustomName = "getVectorY";
	ClassType = Math;
	Description = {
		"@eng:Outputs the `y` component of the `Value` input.\\nIf `Value` does not have a `y` component (if it\'s a 1D vector/scalar), the node outputs `DefaultValue`.\\n\\nIf you simply want to get the `y` component of a 2D, 3D, or 4D vector, this is overkill, simply **use the `.y` swizzle node**.\\n\\nThis node is helpful when making generic templates where you do not know the exact dimension of a vector in advance and want to allow the user to plug in different types of vectors, for example when making a template that processes both RGB and RGBA colors.",
	};
	Public = true;
	IconKey = "Toolbar_Channel_Y";
	SearchKeywords = ".y swizzle extract";
	EmitDeprecationWarning = true;
