CEditorTemplateEntry	$42857AF9
{
	CustomName = "scene.intersect";
	ClassType = Math;
	Description = {
		"@eng:Issues a scene raycast query at location `RayStart`, towards `RayDirection`, as far as `RayLength`.\\n`Radius` can be set to a value greater than zero to perform a sphere sweep instead of a raycast (not all engines might support this).\\n\\nOutputs the `HitPosition`, `HitNormal`, `HitDistance`, and `HitSurfaceType`.\\nThe `Intersects` output tells if something was hit or not.\\n\\nWill only perform the raycast if `Enabled` is `true`. Passing `false` will not perform the raycast for this particle, and the output `Intersects` will always be `false`, and all other output values will be **undefined**.\\n\\n`CollisionFilter` is a 32-bits mask telling the game-engine which parts of the scene should be tested for intersection. The available values are setup in the project settings, in the project constants, prefixed by \"`physics.collisionFilters.`\"\\n",
	};
	Public = true;
	SearchKeywords = "raycast";
	EmitDeprecationWarning = true;
	ObjectUID = -356798828;
	InputTypes = {
		"$C8B0C8B0",
		"$5BBDBD33",
		"$1F42BA72",
		"$92B3D11D",
		"$8A8907A4",
