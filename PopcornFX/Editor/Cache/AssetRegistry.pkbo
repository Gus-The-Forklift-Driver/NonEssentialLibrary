CEditorTemplateEntry	$536B8445
{
	CustomName = "Legacy_Physics2";
	Description = {
		"@eng:**DEPRECATED**\\nUse the `Physics` node instead. This node is kept as legacy due to fix of #12029, where the collision position & normals were not properly transformed back to worldspace when colliding with a localspace shape.\\nTo prevent unwanted regressions following the fix, the `v2.17.0` upgrade patched your effect to use the old behavior instead.\\n\\nPhysics simulation node.\\nWill make your particles move with velocity, acceleration, friction, force-fields, velocity fields, optionally handle collisions, etc...",
	};
