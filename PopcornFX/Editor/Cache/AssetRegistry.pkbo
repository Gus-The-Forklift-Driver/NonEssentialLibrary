CEditorTemplateEntry	$8B0B3E9C
{
	CustomName = "reverse bits";
	ClassType = Math;
	Description = {
		"@eng:Reverses the bits of the input <c>int</c>.\\n\\nThe <c>BitCount</c> property specifies how many bits will be reversed.\\nIf <c>BitCount</c> is lower than <c>32</c>, only these lower bits will be reversed, the upper bits will be cleared.\\n\\nFor example, reversing 15 bits of the 32-bits integer <c>2870431569</c>:\\n<c>0b10101011000101110100111101010001</c>\\nWill give the result:\\n<c>0b00000000000000000100010101111001</c>\\nWhis is <c>17785</c>\\n\\n<b>Performance considerations:</b>\\nMost efficient values for <c>BitCount</c> are <c>4</c>, then <c>8</c>, then <c>32</c>, and finally all other values in-between.",
	};
	Public = true;
	IconKey = "Toolbar_InspectBinary";
	EmitDeprecationWarning = true;
	ObjectUID = -406250430;
	InputTypes = {
		"$C449338F",
		"$270A01FE",
	};
	OutputTypes = {
		"$68FDA999",
	};
}
