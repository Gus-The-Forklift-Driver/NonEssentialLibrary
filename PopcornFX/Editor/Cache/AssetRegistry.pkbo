CEditorTemplateEntry	$5AFC01BA
{
	CustomName = "shape.sampleFromUV";
	ClassType = Sampler;
	Description = {
		"@eng:Samples a location identifier on the shape sampler corresponding to the uv coordinates.\\nThe resulting parametric coordinate can then be passed to the other sampling functions.\\n\\nAs a helper this node will provide all outputs the `shape.sample` node provides, but if you need to re-sample the mesh yourself outside of this node, just grab the `PCoord` output and wire it into other `shape.sample` nodes.\\n\\n<font color=#F55><b>Note</b>: Only available for \'Mesh\' shapes</font>",
	};
