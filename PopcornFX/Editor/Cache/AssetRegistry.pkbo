CEditorTemplateEntry	$5C5BFB37
{
	CustomName = "remap";
	ClassType = Math;
	Description = {
		"@eng:Remaps <c>Value</c> from the <c>[OldMin, OldMax]</c> range to the <c>[NewMin, NewMax]</c> range.\\n\\nAll the function’s arguments can be either scalars, or vectors. If some arguments are vectors, they must have the same dimension. The return value will be a vector as large as the largest input vector.\\n\\nie: you cannot call\\n<c>remap(float2, float3, float4, float3, float3)</c>\\nbut you can call\\n<c>remap(float, float, float4, float, float)</c>\\nor\\n<c>remap(float3, float, float3, float3, float)</c>.\\n",
	};
	Public = true;
	SearchKeywords = "fit";
	EmitDeprecationWarning = true;
