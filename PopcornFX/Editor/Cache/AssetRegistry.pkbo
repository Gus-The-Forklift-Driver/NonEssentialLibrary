CEditorTemplateEntry	$8EDBC7E5
{
	CustomName = "sim.frameStep";
	ClassType = Math;
	Description = {
		"@eng:Returns the frame update rate frequency of the current simulation unit (wavefront).\\n\\nThis value is the number of frames the simulation will **likely** wait before running at this update rate again. There is no guarantee this particle will wait this exact amount of frames before re-running at this update rate. It could be more, it could be less, but it is generally a good approximation.\\n\\n<b>Example:</b> Close-by effects running their `low` update rate graph might have it run **once every 4 frames**.\\nFar-away effects running their `low` update rate graph might have it run **once every 32 frames**.",
	};
	Public = true;
	EmitDeprecationWarning = true;
	ObjectUID = 1049156422;
	OutputTypes = {
		"$2D69620C",
	};
}
