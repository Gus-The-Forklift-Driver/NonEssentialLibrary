CEditorTemplateEntry	$219F8EC4
{
	CustomName = "shape.intersect";
	ClassType = Sampler;
	Description = {
		"@eng:Issues a raycast query against the input `Sampler` shape, at location `RayStart`, towards `RayDirection`, as far as `RayLength`.\\n\\nOutputs the `HitPosition`, `HitNormal`, `HitDistance`, and `HitPCoords`.\\nThe `Intersects` output tells if something was hit or not.\\n\\nWill only perform the raycast if `Enabled` is `true`. Passing `false` will not perform the raycast for this particle, and the output `Intersects` will always be `false`, and all other output values will be **undefined**.\\n",
	};
	Public = true;
	IconKey = "Sampler_Shape";
	SearchKeywords = "raycast collide collision mesh";
	EmitDeprecationWarning = true;
