CEditorTemplateEntry	$B898D42F
{
	CustomName = "curve.probabilitySample";
	ClassType = Sampler;
	Description = {
		"@eng:Treats the curve sampler curve as a Probability Density Function (PDF), and samples its Cumulative Density Function (CDF) at `x=cursor`\\nOnly works for `float` curves (single channel / 1D), and curves whose `IsDensityCurve` property has been checked.\\nUseful to get custom random distributions by doing `Curve.sampleCDF(rand(0,1))`",
	};
