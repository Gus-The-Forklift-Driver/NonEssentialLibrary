CEditorTemplateEntry	$B5BDB77C
{
	CustomName = "smoothlerp";
	ClassType = Math;
	Description = {
		"@eng:Smoothly blends between <c>Min</c> and <c>Max</c> using <c>Value</c> as an interpolation cursor.\\n\\n<c>Value</c> is expected to be in the [0, 1] range. When it equals <c>0.0</c>, <c>Min</c> is returned, when it equals <c>1.0</c>, <c>Max</c> is returned.\\nValues in between return values between <c>Min</c> and <c>Max</c>.\\n\\nEquivalent to\\n<c>lerp(Min, Max, smoothstep(0, 1, Value));</c>\\nOr\\n<c>lerp(Min, Max, 3*pow(Value,2) - 2*pow(Value,3));</c>",
	};
	Public = true;
	IconKey = "Node_Math_Lerp";
	EmitDeprecationWarning = true;
	ObjectUID = 1222830263;
	InputTypes = {
		"$369EADEF",
		"$EBD5DBDE",
		"$F5C798F9",
	};
	OutputTypes = {
		"$83EE3EB0",
	};
}
