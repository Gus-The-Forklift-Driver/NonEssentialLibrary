CEditorTemplateEntry	$07721CCC
{
	CustomName = "SI_SceneRaycast";
	ClassType = Sampler;
	Description = {
		"@eng:Issues a scene raycast query at location <c>RayStart</c>, towards <c>RayDirection</c>, as far as <c>RayLength</c>.\\n<c>Radius</c> can be set to a value greater than zero to perform a sphere sweep instead of a raycast (not all engines might support this).\\n\\nOutputs the <c>HitPosition</c>, <c>HitNormal</c>, <c>HitDistance</c>, and <c>HitSurfaceType</c>.\\nThe <c>Intersects</c> output tells if something was hit or not.\\n\\nWill only perform the raycast if <c>Enabled</c> is <c>true</c>. Passing <c>false</c> will not perform the raycast for this particle, and the output <c>Intersects</c> will always be <c>false</c>, and all other output values will be <b>undefined</b>.\\n\\n<c>CollisionFilter</c> is a 32-bits mask telling the game-engine which parts of the scene should be tested for intersection.\\n",
	};
	EmitDeprecationWarning = true;
	ObjectUID = 579393480;
	InputTypes = {
