CEditorTemplateEntry	$DDF000E6
{
	CustomName = "setdim";
	ClassType = Math;
	Description = {
		"@eng:Sets the dimension of input `Value` to be `Dimension`. It will crop or extend the input appropriately so the output has `Dimension` components.\\nif `Dimension` is greated than the input dimension, it will insert the extra components using the `FillWith` input.\\nIf `FillWith` is a scalar, it will broadcast it to the new components, if it is a vector, it will pick the new components from the corresponding components in `FillWith`, and if `FillWith` has a smaller dimension than `Dimension`, the last component of `FillWith` will be extended to the remaining channels.\\nSet `FillWith` to the same as `Value` if you wish to extend the last component of `Value` in the new channels.",
	};
	Public = true;
	SearchKeywords = "vector setdimension setorder crop extend";
	EmitDeprecationWarning = true;
	ObjectUID = 1776659710;
	InputTypes = {
		"$48929EA1",
		"$E2F56178",
	};
	OutputTypes = {
		"$6CC6619B",
	};
}
