CEditorTemplateEntry	$D5E8E464
{
	CustomName = "Projection";
	Description = {
		"@eng:Reprojects particles on a shape each frame, projecting both the `Position` & `Velocity` so the particle properly flows along the shape surface.\\nYou can typically use this by chaining it after a physics node.\\n\\nThis node will use discretization paths and force stores on the output `Position` & `Velocity`. If you do not want the forced discretization, use the `Projection_NoStore` node instead.",
	};
	Public = true;
	SearchKeywords = "surface";
	EmitDeprecationWarning = true;
