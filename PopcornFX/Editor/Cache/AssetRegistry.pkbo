{
	CustomName = "Ticker";
	ClassType = Math;
	Description = {
		"@eng:This node contains a timer that will tick at a fixed rate, and set the `HasTicked` output to `true` for 1 frame every `Delay` seconds.\\nThis is useful to refresh some states in your simulations at a fixed rate.\\nThere is no way to tell if `Delay` is smaller than the update time of 1 frame and if there was 2 or more ticks in a single frame. The `HasTicked` will simply be `true` for the frames where multiple ticks happen.",
	};
	Public = true;
	IconKey = "Toolbar_Timer";
	EmitDeprecationWarning = true;
	ObjectUID = -171291650;
	InputTypes = {
