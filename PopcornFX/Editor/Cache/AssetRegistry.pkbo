CEditorTemplateEntry	$1FB1B2C7
{
	CustomName = "GBuffer_ProjectToPosition";
	Description = {
		"@eng:Projects the input world position onto the GBuffer and extracts a depth at that location, converted to a world position:\\n<ul>\\n<li><b>Input position</b> is converted to <b>screen space coordinates</b></li>\\n<li><b>Screen space coordinates</b> are used to sample the <b>Depth buffer</b></li>\\n<li><b>Sampled depth</b> is converted to a <b>world position</b></li>\\n</ul>\\n<c>Only supported if used with GPU simulated particles</c>.\\n\\nTo enable that feature in PopcornFX Editor, browse to <b>Project Settings > Features</b> and make sure to enable <b>GBuffer Sampling</b>.",
	};
	Public = true;
	IconKey = "Renderer_Decal";
	SearchKeywords = "GBuffer Project";
	EmitDeprecationWarning = true;
	ObjectUID = 1361867206;
	InputTypes = {
		"$F0285596",
	};
	OutputTypes = {
		"$7D423911",
	};
}
