CEditorTemplateEntry	$9B00DE7E
{
	CustomName = "Counter";
	ClassType = Math;
	Description = {
		"@eng:This node will count how many times the input <c>Condition</c> has been <c>true</c>.\\n\\nEvery frame, <c>Condition</c> is evaluated, and if it is <c>true</c>, the value will be incremented by <c>1</c>.\\n\\nThe <c>Enabled</c> property allows to enable/disable the counter entirely.\\nWhen <c>Enabled</c> is <c>false</c>, it will ignore the <c>Condition</c> input and never increment the value.",
	};
	Public = true;
	EmitDeprecationWarning = true;
	ObjectUID = 2096828476;
	InputTypes = {
		"$91178019",
