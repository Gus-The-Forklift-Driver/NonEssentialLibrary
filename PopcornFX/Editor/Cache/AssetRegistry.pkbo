CEditorTemplateEntry	$3A524192
{
	CustomName = "ContainInBox";
	Description = {
		"@eng:This node generates a random point inside a box, and contains it inside as the box moves around.\\n\\nYou can wire this in the input <c>Position</c> of a <c>Physics</c> node, or any other node which is modifying the point at evolve.\\n\\nThe containment box is defined by the input <c>Position</c>, <c>Orientation</c>, and <c>Scale</c>.\\n\\n<c>Scale</c> is the half-width (radius) of the box. IE: it scales a <c>[-1,1]</c> unit-box.",
	};
	Public = true;
	IconKey = "Toolbar_Bounds";
	SearchKeywords = "Wrap";
	EmitDeprecationWarning = true;
	ObjectUID = -709176010;
	InputTypes = {
