CEditorTemplateEntry	$2D9F4266
{
	CustomName = "grid.reduce";
	ClassType = Sampler;
	Description = {
		"@eng:Reads the values of all cells from the input `Grid` that are inside the region defined by `QuerySize`.\\nOn 2D grids, `QuerySize` is a rectangle that starts at texel `ID` and extends on the X and Y coordinates by `QuerySize.x` and `QuerySize.y` cells.\\nOn 3D grids, it is a cube, on 1D grids, it is a segment, etc.\\n\\nThe values of all cells inside this region will be combined together based on the specified `Mode`, and the final `Value` will be output by the node.\\n\\n`QuerySize` can vary per-particle but the query will be the most efficient if it is constant across all particles.\\n\\nThe most efficient queries are constant size queries on the X axis: `QuerySize = { N, 1, 1, 1 }`\\n",
	};
	Public = true;
	IconKey = "Sampler_Grid";
	SearchKeywords = "array";
	EmitDeprecationWarning = true;
	ObjectUID = 1747504823;
	InputTypes = {
		"$41EA3E21",
		"$3ECDB6F8",
