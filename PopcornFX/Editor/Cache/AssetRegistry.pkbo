CEditorTemplateEntry	$95919567
{
	CustomName = "Luminance";
	ClassType = Math;
	Description = {
		"@eng:Computes the grayscale / luminance of the input `Color`.\\n\\nAllows to pick between different luminance computation modes:<ul>\\n<li>**`Luminance`**: CIE Luminance. \"Proper luminance\", weighted based on human eye response to perceived intensities. **Fast to compute**.</li>\\n<li>**`Perceptual`**: CIE LAB perceptual luminance. **Slow to compute**.</li>\\n<li>**`RGB Average`**: Simple average of R, G, and B components of the input color. **Fast to compute**.</li>\\n</ul>",
	};
	Public = true;
	IconKey = "Toolbar_PaintPalette";
	SearchKeywords = "color constructor assembler";
	EmitDeprecationWarning = true;
	ObjectUID = 692239251;
	InputTypes = {
