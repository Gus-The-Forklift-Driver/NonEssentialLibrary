CEditorTemplateEntry	$093EF2CC
{
	CustomName = "vrand";
	ClassType = Math;
	Description = {
		"@eng:Outputs a random <c>float3</c> vector uniformly distributed on the unit sphere surface.\\n<c>vrand()</c> stands for \"vector rand\".\\nUseful to generate nicely distributed random normals, random 3D offsets, or other unit vectors to give a bit of randomization to particle velocities, etc...\\n\\nChanging the <c>Inner</c> and <c>Outer</c> parameters allows you to generate a point in a shperical shell instead of a sphere surface.\\nSet <c>Inner</c> to <c>0.0</c> and <c>Outer</c> to <c>1.0</c> to generate an uniform point inside the volume of an unit-sphere.\\n\\nWiring a <b>1D curve</b> inside the <c>Distribution</c> input will change the random distribution between the <c>Inner</c> and <c>Outer</c> radii, using the curve as a probability distribution.",
	};
	Public = true;
	IconKey = "Node_PointSphere";
	EmitDeprecationWarning = true;
	ObjectUID = 1262809734;
	InputTypes = {
		"$665FE37F",
		"$C1BD78AE",
		"$FE560E09",
		"$C9845100",
	};
	OutputTypes = {
		"$27E8C3C3",
	};
}
