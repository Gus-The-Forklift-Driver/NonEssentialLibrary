CEditorTemplateEntry	$59CD808C
{
	CustomName = "Legacy_Collision2";
	Description = {
		"@eng:**DEPRECATED**\\nUse the `Collision` node instead. This node is kept as legacy due to fix of #12029, where the collision position & normals were not properly transformed back to worldspace when colliding with a localspace shape.\\nTo prevent unwanted regressions following the fix, the `v2.17.0` upgrade patched your effect to use the old behavior instead.\\n",
	};
