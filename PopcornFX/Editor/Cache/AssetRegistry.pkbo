CEditorTemplateEntry	$C06F9553
{
	CustomName = "EventTriggerOnce";
	ClassType = Event;
	GraphUsage = SimulationGraph;
	Description = {
		"@eng:Triggers a single event.\\n\\nOnce the `Condition` has been `true` at least once and the event has been triggered, subsequent frames where `Condition` is true will be ignored, and no more events will be pulsed.\\n\\nBasic trigger, does not add any helper payloads.\\nSee `TriggerOnce` if you need some base payloads.",
	};
	Public = true;
	IconKey = "Node_Event";
	EmitDeprecationWarning = true;
