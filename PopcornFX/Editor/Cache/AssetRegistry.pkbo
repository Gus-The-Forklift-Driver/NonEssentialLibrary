{
	CustomName = "WrapInBox";
	Description = {
		"@eng:This node wraps a 3D coordinate so that it is contained inside an unit-box, transformed by the input <c>Position</c>, <c>Orientation</c>, and <c>Scale</c>.\\n\\n<c>Scale</c> is the half-width (radius) of the box. IE: it scales a <c>[-1,1]</c> unit-box.",
	};
