CEditorTemplateEntry	$B8696D11
{
	CustomName = "randsign";
	ClassType = Math;
	Description = {
		"@eng:Randomly returns <c>-1.0</c> or <c>1.0</c>.\\n\\n<c>randsign(Cursor)</c> is equivalent to <c>randsel(-1.0, 1.0, Cursor)</c>, or when <c>Cursor = 0.5</c>, to <c>sign(rand(-1,1))</c>.\\n\\nChanging the value of <c>Cursor</c> will bias the probability towards the first or second input:\\n<c>Cursor = 0.1</c> will have a <b>10% chance</b> of returning <c>1.0</c>, and a <b>90% chance</b> of returning <c>-1.0</c>.\\n<c>Cursor = 0.75</c> will have a <b>75% chance</b> of returning <c>1.0</c>, and a <b>25% chance</b> of returning <c>-1.0</c>.\\n\\nlogic:\\n<c>select(-1.0, 1.0, rand(0,1) < k);</c>\\n",
	};
	Public = true;
	IconKey = "Node_Math_Rand";
	EmitDeprecationWarning = true;
	ObjectUID = -722835984;
	InputTypes = {
		"$0CC418A8",
	};
	OutputTypes = {
		"$2C42D08B",
	};
}
