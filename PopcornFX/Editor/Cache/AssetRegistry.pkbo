CEditorTemplateEntry	$804AA1AA
{
	CustomName = "StoreIf";
	ClassType = Math;
	Description = {
		"@eng:Keeps track of a value and allows to update that value whenever a custom condition becomes `true`.\\n\\nThe initial value before `DoStore` becomes `true` for the first time will always be the value of `NewValue`, evaluated at spawn time.\\n\\nThis is useful because by default everything is evaluated each frame.\\nSo for example if you want to pick a random color based on a specific condition happening (ex: a collision happened this frame), every frame will compute a new random color, but using this node will allow to \"remember\" just the random color only on the frames where the condition is `true`.",
	};
	Public = true;
	IconKey = "Toolbar_Download";
	SearchKeywords = "write assign";
	EmitDeprecationWarning = true;
	ObjectUID = 868950266;
	InputTypes = {
		"$40B1ACB5",
		"$D5DFBF1C",
	};
	OutputTypes = {
		"$4BFF7E0F",
	};
}
