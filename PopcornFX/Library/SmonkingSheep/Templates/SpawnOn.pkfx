	WorkspacePosition = int2(-836, 1496);
	Expression = "float u = UVW.x;
float v = UVW.y;
float w = UVW.z;

bool a = (u + v > 1.0f);
u = iif( a,1.0f - u,u);
v = iif( a,1.0f - v,v);

float oldW = w;
bool b = (v + w > 1.0f);
bool c = (u + v + w > 1.0f);
w = iif( b,1.0f - u - v,w);
v = iif( b,1.0f - oldW,v);

w = iif( c && !b,u + v + w - 1.0f,w);
u = iif( c && !b,1.0f - v - oldW,u);

UVW = float3(u,v,w);";
}
