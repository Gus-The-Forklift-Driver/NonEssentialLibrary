	WorkspacePosition = int2(-572, 902);
	Expression = "// Compute the mesh pcoord:
int3	pcMesh = 	iif(SampleDimensionality == 2,	// volume
						shape.buildPCoordsMesh(ElementID, UVW),
					iif(SampleDimensionality == 1,	// surface
						shape.buildPCoordsMesh(ElementID, UV),
						shape.buildPCoordsMesh(ElementID)));	// vertex
Pcoord = pcMesh;";
}
