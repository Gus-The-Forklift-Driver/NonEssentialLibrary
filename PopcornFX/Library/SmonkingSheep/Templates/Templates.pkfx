CParticleNodeScript	$438D0505
{
	CustomName = {
		"@eng:Accumulator",
	};
	InputPins = {
		"$5CE8F117",
	};
	OutputPins = {
		"$AB1B3015",
	};
	WorkspacePosition = int2(-462, -110);
	Expression = "// Build the int2 accumuator expected by the event generator node
// by packing the raw bits of the spawn fraction, and the initial emitted count:

int		initialEmittedCount = 0;
float	epsilon = 1.0e-3f;	// In theory should be 0.0
float	initialSpawnFraction = (1.0 - epsilon) - FirstSpawnDelay * (1.0 - 2.0 * epsilon);
InitialAccum = int2(asint(initialSpawnFraction), initialEmittedCount);
";
}
