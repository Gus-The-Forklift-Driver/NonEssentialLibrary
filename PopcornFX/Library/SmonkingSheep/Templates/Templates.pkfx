CParticleNodeScript	$EDAA28AF
{
	InputPins = {
		"$062FEE5B",
		"$DD782DBE",
		"$3FCB722E",
		"$197796E9",
		"$446A4CF5",
	};
	OutputPins = {
		"$AEC2564A",
	};
	WorkspacePosition = int2(-88, -132);
	Expression = "Value = (t*((2-t)*t - 1) * p_1 + (t*t*(3*t - 5) + 2) * p0 + t*((4 - 3*t)*t + 1) * p1 + (t-1)*t*t * p2 ) / 2";
}
