CParticleNodeGraph	$D3EC2F33
{
	CustomName = "Catmull-RomInterpolation";
	Description = {
		"@eng:Interpolates beetween multiple points using Catmull-Rom interpolation.\\nThe cursor represents the interpolation beetween 0 and 1.",
	};
	Public = true;
	Nodes = {
		"$EDAA28AF",
		"$9F160297",
		"$453EF8D9",
		"$AE3C421A",
