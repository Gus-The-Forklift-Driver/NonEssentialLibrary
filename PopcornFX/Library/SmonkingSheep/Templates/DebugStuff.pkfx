CParticleNodeScript	$FEB22FE0
{
	ExecStage = Evolve;
	InputPins = {
		"$FFD82541",
		"$DA81B5AC",
		"$9F6ED5C0",
		"$899752D2",
		"$50EE4F63",
	};
	WorkspacePosition = int2(528, -308);
	Expression = "//inputs
//Pos - float3
//Rot - orientation
//Scl - float3
//Color - float4
//Enabled - bool
//vertices
float3 v1 = rotate(scene.convert(float3(0.0, 0.0, 0.0), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v0 = rotate(scene.convert(float3(-0.0, 1.0, 0.0), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v4 = rotate(scene.convert(float3(0.055, 0.662, 0.095), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v3 = rotate(scene.convert(float3(0.055, 0.662, -0.095), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v2 = rotate(scene.convert(float3(-0.109, 0.662, 0.0), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
//lines
debug.drawLine(Enabled,v1,v0,Color,Color);
debug.drawLine(Enabled,v0,v4,Color,Color);
debug.drawLine(Enabled,v0,v3,Color,Color);
debug.drawLine(Enabled,v2,v3,Color,Color);
debug.drawLine(Enabled,v2,v0,Color,Color);
debug.drawLine(Enabled,v3,v4,Color,Color);
debug.drawLine(Enabled,v4,v2,Color,Color);";
}
