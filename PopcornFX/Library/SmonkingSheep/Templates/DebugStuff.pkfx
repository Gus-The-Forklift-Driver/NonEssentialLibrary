{
	CustomName = "Gizmo.Vector";
	Description = {
		"@eng:Debug render a gizmo of the same kind.\\n<strong style=\"color: red;\">WARNING : this will destroy your editor fps</strong>\\nUse with caution (or don\'t, IDGAF)",
	};
	Public = true;
	ClassType = Renderer;
	IconKey = "Renderer_Triangle";
	Nodes = {
		"$FEB22FE0",
		"$CF4A1040",
		"$3AD06807",
		"$C4D551E7",
