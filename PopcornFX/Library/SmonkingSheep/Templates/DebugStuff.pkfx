//vertices
float3 v2 = rotate(float3(0.0, 0.5, 0.0),Rot)*Scl+Pos;
float3 v1 = rotate(float3(0.0, 0.0, 0.5),Rot)*Scl+Pos;
float3 v0 = rotate(float3(0.0, 0.0, -0.5),Rot)*Scl+Pos;
float3 v5 = rotate(float3(-0.5, 0.0, 0.0),Rot)*Scl+Pos;
