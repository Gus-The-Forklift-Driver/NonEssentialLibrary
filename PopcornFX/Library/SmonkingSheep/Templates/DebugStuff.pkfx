CParticleNodeScript	$E3CDA438
{
	ExecStage = Evolve;
	InputPins = {
		"$CB73BC06",
		"$2912E85D",
		"$45736592",
		"$2E25AA4A",
		"$4D10CEDD",
	};
	WorkspacePosition = int2(154, -308);
	Expression = "//inputs
//Pos - float3
//Rot - orientation
//Scl - float3
//Color - float4
//Enabled - bool
//vertices
float3 v2 = rotate(float3(-0.5, 0.5, -0.5),Rot)*Scl+Pos;
float3 v0 = rotate(float3(-0.5, -0.5, -0.5),Rot)*Scl+Pos;
float3 v1 = rotate(float3(-0.5, -0.5, 0.5),Rot)*Scl+Pos;
float3 v3 = rotate(float3(-0.5, 0.5, 0.5),Rot)*Scl+Pos;
float3 v6 = rotate(float3(0.5, 0.5, -0.5),Rot)*Scl+Pos;
float3 v7 = rotate(float3(0.5, 0.5, 0.5),Rot)*Scl+Pos;
float3 v4 = rotate(float3(0.5, -0.5, -0.5),Rot)*Scl+Pos;
float3 v5 = rotate(float3(0.5, -0.5, 0.5),Rot)*Scl+Pos;
//lines
debug.drawLine(Enabled,v2,v0,Color,Color);
debug.drawLine(Enabled,v0,v1,Color,Color);
debug.drawLine(Enabled,v1,v3,Color,Color);
debug.drawLine(Enabled,v3,v2,Color,Color);
debug.drawLine(Enabled,v6,v2,Color,Color);
debug.drawLine(Enabled,v3,v7,Color,Color);
debug.drawLine(Enabled,v7,v6,Color,Color);
debug.drawLine(Enabled,v4,v6,Color,Color);
debug.drawLine(Enabled,v7,v5,Color,Color);
debug.drawLine(Enabled,v5,v4,Color,Color);
debug.drawLine(Enabled,v0,v4,Color,Color);
debug.drawLine(Enabled,v5,v1,Color,Color);";
}
