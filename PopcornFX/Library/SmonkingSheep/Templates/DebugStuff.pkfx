CParticleNodeScript	$7294A73F
{
	ExecStage = Evolve;
	InputPins = {
		"$81E33DDC",
		"$894B58D4",
		"$A45FC982",
		"$E080C4FE",
		"$5381C8C5",
	};
	WorkspacePosition = int2(154, -308);
	Expression = "//inputs
//Pos - float3
//Rot - orientation
//Scl - float3
//Color - float4
//Enabled - bool
//vertices
float3 v1 = rotate(scene.convert(float3(0.0, 0.0, 0.0), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v0 = rotate(scene.convert(float3(0.0, 0.0, 1.0), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v4 = rotate(scene.convert(float3(-0.147, -0.085, 0.662), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v3 = rotate(scene.convert(float3(0.147, -0.085, 0.662), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
float3 v2 = rotate(scene.convert(float3(0.0, 0.169, 0.662), axisSystem.RHZUP, scene.coordinateSystem()),Rot)*Scl+Pos;
//lines
debug.drawLine(Enabled,v1,v0,Color,Color);
debug.drawLine(Enabled,v0,v4,Color,Color);
debug.drawLine(Enabled,v0,v3,Color,Color);
debug.drawLine(Enabled,v2,v3,Color,Color);
debug.drawLine(Enabled,v2,v0,Color,Color);
debug.drawLine(Enabled,v3,v4,Color,Color);
debug.drawLine(Enabled,v4,v2,Color,Color);";
}
